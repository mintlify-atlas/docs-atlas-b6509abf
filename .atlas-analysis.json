  "keyFeatures": [
    "ID-based authentication for institutional access control",
    "Multi-role support (Student, Employee, Contractor)",
    "Automatic blocking system based on failure accumulation",
    "Real-time admin dashboard with statistics and metrics",
    "Excel report generation and CSV bulk data upload",
    "Supabase/PostgreSQL database with RLS policies",
    "Clean architecture with domain-driven design",
    "Corporate UCC branding with institutional colors"
  ],
  "publicApiSurface": [
    "POST /api/auth/login - Validate institutional ID",
    "GET /api/usuarios/:id - Get user profile with roles",
    "POST /api/registro-falla - Report TIC failure (olvido/perdida/robo)",
    "GET /api/admin/dashboard - Get admin dashboard statistics",
    "POST /api/admin/desbloquear - Unblock user",
    "GET /api/admin/reportes/:tipo - Export Excel reports",
    "POST /api/admin/carga-csv - Bulk upload CSV data",
    "GET /api/admin/usuarios - List all users with filtering"
  ]
